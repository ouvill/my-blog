{
  "name": "ouvill-blog",
  "private": true,
  "description": "Ouvill のブログ — Astro-based static blog",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro",
    "format": "prettier --write 'src/**/*.{astro,ts,tsx,js,jsx}'",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:check": "npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.0.2",
    "satori": "^0.26.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
