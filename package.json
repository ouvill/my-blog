{
  "name": "ouvill-blog",
  "private": true,
  "description": "Ouvill のブログ — Astro-based static blog",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro",
    "format": "prettier --write 'src/**/*.{astro,ts,tsx,js,jsx}'",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:check": "npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.4.6",
    "satori": "^0.26.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "prettier": "^2.8.1",
    "typescript": "^5.7.0",
    "wrangler": "^4.100.0"
  }
}
