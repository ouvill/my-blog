---
import type { CollectionEntry } from "astro:content"
import { entryIdToSlug, blogUrlPath } from "@lib/slug"
import { resolveCover, DEFAULT_COVER } from "@lib/cover"

export interface Props {
  post: CollectionEntry<"blog">
}

const { post } = Astro.props
const slug = entryIdToSlug(post.id)
const href = blogUrlPath(slug)
const dateStr = post.data.date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
})
const visibleTags: string[] = post.data.tags?.slice(0, 4) ?? []
const coverUrl = resolveCover(post)
const hasCover = coverUrl !== DEFAULT_COVER
---

<article class="post-card">
  <a href={href} class="post-card-link">
    {hasCover && (
      <div class="post-card-cover">
        <img
          src={coverUrl}
          alt=""
          loading="lazy"
          class="cover-image"
        />
      </div>
    )}
    <div class="post-card-content">
      <time class="post-date" datetime={post.data.date.toISOString()}>
        {dateStr}
      </time>
      <h2 class="post-title">{post.data.title}</h2>
      {post.data.description && (
        <p class="post-description">{post.data.description}</p>
      )}
      {visibleTags.length > 0 && (
        <div class="post-tags">
          {visibleTags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .post-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #fce4ec;
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 300ms ease;
  }

  .post-card:hover .cover-image {
    transform: scale(1.05);
  }

  .post-card-content {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-date {
    font-size: 0.875rem;
    color: #888;
  }

  .post-title {
    margin: 8px 0 0;
    font-size: 1.125rem;
    line-height: 1.5;
    color: #333;
  }

  .post-card:hover .post-title {
    color: #f48fb1;
  }

  .post-description {
    margin: 8px 0 0;
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    flex: 1;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 12px;
  }

  .tag {
    background: #fce4ec;
    color: #f48fb1;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
  }
</style>
