---
import type { CollectionEntry } from "astro:content"
import { blogEntryIdToSlug, blogUrlPath } from "@lib/slug"
import { resolveCoverImageOrNull } from "@lib/cover"
import { getPostCategory, getPostTags, taxonomyPath } from "@lib/taxonomy"

export interface Props {
  post: CollectionEntry<"blog">
}

const { post } = Astro.props
const slug = blogEntryIdToSlug(post.id)
const href = blogUrlPath(slug)
const dateStr = post.data.date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
const allTags = getPostTags(post)
const category = getPostCategory(post)
const cover = resolveCoverImageOrNull(post)
---

<article class={`post-card${cover ? " post-card--with-cover" : ""}`}>
  <a
    href={href}
    class="post-card-hit-area"
    aria-label={`${post.data.title} を読む`}
  >
  </a>
  <div class="post-card-content">
    <div class="post-meta">
      <time class="post-date" datetime={post.data.date.toISOString()}>
        {dateStr}
      </time>
      {
        category && (
          <a
            href={taxonomyPath("categories", category)}
            class="post-category"
            aria-label={`${category} カテゴリの記事を見る`}
          >
            {category}
          </a>
        )
      }
    </div>
    <h2 class="post-title">
      <a href={href}>{post.data.title}</a>
    </h2>
    {
      post.data.description && (
        <p class="post-description">{post.data.description}</p>
      )
    }
    {
      allTags.length > 0 && (
        <div class="post-tags">
          {allTags.slice(0, 5).map((tag) => (
            <a
              href={taxonomyPath("tags", tag)}
              class="tag"
              aria-label={`${tag} タグの記事を見る`}
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
  {
    cover && (
      <a href={href} class="post-card-cover-link" aria-label={post.data.title}>
        <div class="post-card-cover">
          <img
            src={cover.src}
            alt=""
            loading="lazy"
            width={cover.width}
            height={cover.height}
            class="cover-image"
          />
        </div>
      </a>
    )
  }
</article>

<style>
  .post-card {
    position: relative;
    background: var(--color-surface);
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition:
      transform 250ms ease,
      box-shadow 250ms ease,
      border-color 250ms ease;
    box-shadow: var(--shadow-card);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: stretch;
  }

  .post-card--with-cover {
    grid-template-columns: minmax(0, 1fr) minmax(164px, 28%);
  }

  .post-card-hit-area {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: color-mix(
      in srgb,
      var(--color-accent) 30%,
      var(--color-border)
    );
  }

  .post-card-cover-link {
    position: relative;
    z-index: 2;
    text-decoration: none;
    color: inherit;
    display: block;
    min-height: 100%;
  }

  .post-card-cover {
    height: 100%;
    min-height: 150px;
    overflow: hidden;
    background: var(--color-accent-soft);
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 250ms ease;
  }

  .post-card:hover .cover-image {
    transform: scale(1.04);
  }

  .post-card-content {
    position: relative;
    z-index: 2;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-category {
    position: relative;
    z-index: 3;
    pointer-events: auto;
    padding: 2px 9px;
    border-radius: 9999px;
    background: var(--color-support-soft);
    color: var(--color-support);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.6;
    text-decoration: none;
  }

  .post-category:hover {
    color: var(--color-support-strong);
    background: color-mix(
      in srgb,
      var(--color-support-soft) 72%,
      var(--color-surface)
    );
  }

  .post-title {
    margin: 12px 0 0;
    font-size: 1.2rem;
    line-height: 1.5;
    font-family: var(--font-heading);
    font-weight: 700;
    font-feature-settings: "palt";
    color: var(--color-text);
  }

  .post-title a {
    position: relative;
    z-index: 3;
    pointer-events: auto;
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }

  .post-title a:hover {
    color: var(--color-accent);
  }

  .post-description {
    margin: 10px 0 0;
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 12px;
  }

  .tag {
    position: relative;
    z-index: 3;
    pointer-events: auto;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 2px 10px;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
  }

  .tag:hover {
    color: var(--color-accent-strong);
    background: color-mix(
      in srgb,
      var(--color-accent-soft) 72%,
      var(--color-surface)
    );
  }

  @media (max-width: 640px) {
    .post-card--with-cover {
      grid-template-columns: 1fr;
    }

    .post-card-cover {
      aspect-ratio: 16 / 9;
      min-height: 0;
    }

    .post-card-content {
      padding: 18px;
    }

    .post-title {
      font-size: 1.08rem;
    }
  }
</style>
