---
import { SITE_CONFIG } from "@lib/site"

export interface Props {
  isHome?: boolean
}

const { isHome = false } = Astro.props
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-top">
      <nav class="site-nav">
        <a href="/">ブログ</a>
        <a href="/contact/">お問い合わせ</a>
      </nav>
    </div>
    <div class="header-center">
      <h1 class="site-title">
        <a href="/">{SITE_CONFIG.title}</a>
      </h1>
      {isHome && <p class="site-description">{SITE_CONFIG.description}</p>}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 0;
    color: #fff;
    background: linear-gradient(135deg, #c2185b 0%, #d81b60 100%);
    overflow: hidden;
  }

  .header-inner {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .header-inner::before {
    position: absolute;
    bottom: -80px;
    left: 0;
    right: 0;
    height: 80px;
    content: "";
    background: linear-gradient(135deg, #c2185b 0%, #d81b60 100%);
  }

  .header-top {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 100;
    padding: 12px 20px;
  }

  .site-nav {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .site-nav a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 200ms ease;
  }

  .site-nav a:hover {
    opacity: 0.75;
    color: #fff;
  }

  .site-nav a:focus-visible,
  .site-title a:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
    border-radius: 2px;
  }

  .header-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 16px 40px;
  }

  @media (max-width: 640px) {
    .header-center {
      padding: 52px 12px 32px;
    }
  }

  .site-title {
    margin: 0;
    font-size: 1.75rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .site-title {
      font-size: 2rem;
    }
  }

  .site-title a {
    box-shadow: none;
    text-decoration: none;
    color: inherit;
  }

  .site-description {
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
  }
</style>
