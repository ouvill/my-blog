---
import { SITE_CONFIG } from "@lib/site"

export interface Props {
  isHome?: boolean
}

const { isHome = false } = Astro.props
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-top">
      <nav class="site-nav">
        <a href="/">ブログ</a>
        <a href="/contact">お問い合わせ</a>
      </nav>
    </div>
    <div class="header-center">
      <h1 class="site-title">
        <a href="/">{SITE_CONFIG.title}</a>
      </h1>
      {isHome && <p class="site-description">{SITE_CONFIG.description}</p>}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 0;
    height: 320px;
    color: #333;
    background: linear-gradient(135deg, #f48fb1 0%, #fce4ec 100%);
    overflow: hidden;
  }

  .header-inner {
    position: relative;
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .header-inner::before {
    position: absolute;
    bottom: -100px;
    left: 0;
    right: 0;
    height: 100px;
    content: "";
    background: linear-gradient(135deg, #f48fb1 0%, #fce4ec 100%);
  }

  .header-top {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 100;
    padding: 8px 16px;
  }

  .site-nav {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .site-nav a {
    text-decoration: none;
    color: white;
    font-weight: 600;
    transition: opacity 400ms ease;
  }

  .site-nav a:hover {
    opacity: 0.7;
  }

  .header-center {
    position: relative;
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .site-title {
    margin: 0;
    font-size: 2rem;
    text-align: center;
  }

  .site-title a {
    box-shadow: none;
    text-decoration: none;
    color: inherit;
  }

  .site-description {
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
  }
</style>
