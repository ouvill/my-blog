---
import BaseLayout from "@components/BaseLayout.astro"

const status = Astro.url.searchParams.get("status")

interface StatusMessage {
  readonly type: "error" | "info"
  readonly heading: string
  readonly body: string
}

const STATUS_MESSAGES: Record<string, StatusMessage> = {
  invalid_request: {
    type: "error",
    heading: "リクエストの形式が正しくありません",
    body: "フォームの内容を確認して、もう一度送信してください。",
  },
  validation_error: {
    type: "error",
    heading: "入力内容に修正が必要です",
    body: "フォームの内容を確認して、もう一度送信してください。",
  },
  server_error: {
    type: "error",
    heading: "送信処理で問題が発生しました",
    body: "時間をおいて、もう一度送信してください。問題が続く場合はメールまたは Twitter DM でお問い合わせください。",
  },
}

const currentMessage: StatusMessage | undefined = status
  ? STATUS_MESSAGES[status]
  : undefined
---

<BaseLayout title="お問い合わせ">
  <div class="contact-page">
    <h1>お問い合わせ</h1>

    <p class="contact-intro">
      ご依頼やご質問など、以下のフォームからお気軽にお送りください。
    </p>

    {currentMessage && (
      <div class:list={["status-message", { error: currentMessage.type === "error" }]} role="alert" aria-live="assertive">
        <p class="status-heading">{currentMessage.heading}</p>
        <p class="status-body">{currentMessage.body}</p>
      </div>
    )}

    <form
      method="POST"
      action="/api/contact"
      class="contact-form"
    >
      <!-- Honeypot field: visually hidden, bots will fill it in -->
      <div aria-hidden="true" class="honeypot">
        <label for="botField">このフィールドは入力しないでください</label>
        <input id="botField" name="botField" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <div class="form-field">
        <label for="field-name">
          お名前（ペンネーム可）<span class="required" aria-label="必須">*</span>
        </label>
        <input id="field-name" name="name" type="text" required />
      </div>

      <div class="form-field">
        <label for="field-email">
          メールアドレス<span class="required" aria-label="必須">*</span>
        </label>
        <input id="field-email" name="email" type="email" required />
      </div>

      <div class="form-field">
        <label for="field-context">
          お問い合わせ内容<span class="required" aria-label="必須">*</span>
        </label>
        <textarea id="field-context" name="context" rows="6" required></textarea>
      </div>

      <button type="submit" class="submit-button">送信する</button>
    </form>

    <div class="contact-fallback">
      <p>
        フォームがうまく動作しない場合は、以下のメールアドレスまで直接ご連絡ください。
      </p>
      <p class="email">
        <a href="mailto:contact@ouvill.net">contact@ouvill.net</a>
      </p>
      <p>
        または、<a href="https://twitter.com/Ouvill" target="_blank" rel="noopener noreferrer">Twitter</a>のDMでも受け付けております。
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 16px;
    background: var(--color-surface, #fff);
    border-radius: 4px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .contact-page h1 {
    margin: 0 0 16px;
  }

  .contact-intro {
    margin-bottom: 24px;
    color: var(--color-text-secondary, #555);
    line-height: 1.7;
  }

  /* ---- Status message ---- */
  .status-message {
    margin-bottom: 24px;
    padding: 16px;
    border-radius: 4px;
    border-left: 4px solid var(--color-primary, #c2185b);
    background: var(--color-primary-light, #fce4ec);
  }

  .status-heading {
    margin: 0 0 4px;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text, #1a1a1a);
  }

  .status-body {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #555);
    line-height: 1.7;
  }

  /* ---- Honeypot: visually hidden for humans, present for bots ---- */
  .honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    overflow: hidden;
  }

  /* ---- Form ---- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text, #1a1a1a);
  }

  .required {
    color: var(--color-primary, #c2185b);
    margin-left: 2px;
  }

  .form-field input,
  .form-field textarea {
    font-family: var(--font-sans, sans-serif);
    font-size: 1rem;
    padding: 10px 12px;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    background: var(--color-bg, #f7f7f7);
    color: var(--color-text, #1a1a1a);
    transition: border-color 200ms ease, box-shadow 200ms ease;
    line-height: 1.5;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: 2px solid var(--color-primary, #c2185b);
    outline-offset: 1px;
    border-color: var(--color-primary, #c2185b);
    box-shadow: 0 0 0 3px var(--color-primary-light, #fce4ec);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-button {
    display: inline-block;
    align-self: flex-start;
    padding: 12px 32px;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-sans, sans-serif);
    color: #fff;
    background: var(--color-primary, #c2185b);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 200ms ease;
  }

  .submit-button:hover {
    background: var(--color-primary-dark, #880e4f);
  }

  .submit-button:focus-visible {
    outline: 2px solid var(--color-primary, #c2185b);
    outline-offset: 2px;
  }

  /* ---- Fallback contact info ---- */
  .contact-fallback {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border, #e0e0e0);
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #555);
  }

  .contact-fallback p {
    margin: 0 0 8px;
    line-height: 1.7;
  }

  .email {
    font-size: 1.125rem;
    text-align: center;
    padding: 12px;
    margin: 12px 0;
    background: var(--color-primary-light, #fce4ec);
    border-radius: 8px;
  }

  .email a {
    font-weight: 600;
    color: var(--color-primary, #c2185b);
    text-decoration: none;
  }

  .email a:hover {
    text-decoration: underline;
  }
</style>
