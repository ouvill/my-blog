---
import BaseLayout from "@components/BaseLayout.astro"
---

<BaseLayout title="お問い合わせ">
  <div class="contact-page">
    <h1>お問い合わせ</h1>
    <p>
      ご依頼やご質問などございましたら、以下のメールアドレスまでご連絡ください。
    </p>
    <p class="email">
      <a href="mailto:contact@ouvill.net">contact@ouvill.net</a>
    </p>
    <p>
      または、<a href="https://twitter.com/Ouvill" target="_blank" rel="noopener noreferrer">Twitter</a>のDMでも受け付けております。
    </p>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 16px;
    background: white;
    border-radius: 4px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .contact-page h1 {
    margin: 0 0 16px;
  }

  .email {
    font-size: 1.25rem;
    text-align: center;
    padding: 16px;
    background: #fce4ec;
    border-radius: 8px;
  }
</style>
