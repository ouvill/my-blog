---
import BaseLayout from "@components/BaseLayout.astro"
import PostCard from "@components/PostCard.astro"
import { getAllPosts } from "@lib/posts"
import { getPaginationInfo, getPageSlice } from "@lib/pagination"
import { SITE_CONFIG, POSTS_PER_PAGE } from "@lib/site"

const defaultOgImage = `${SITE_CONFIG.url}/site-header.jpg`

export interface Params {
  page: string
}

export async function getStaticPaths() {
  const allPosts = await getAllPosts()
  const total = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE))
  const paths = []
  for (let i = 0; i < total; i++) {
    paths.push({ params: { page: String(i) } })
  }
  return paths
}

const { page } = Astro.params
const pageNum = parseInt(page ?? "0", 10)

const allPosts = await getAllPosts()
const pagination = getPaginationInfo(allPosts.length, pageNum)
const pagePosts = getPageSlice(allPosts, pageNum)
---

<BaseLayout title={`${SITE_CONFIG.title} — ${pageNum + 1}ページ目`} isHome={true} image={defaultOgImage}>
  <div class="index-wrap">
    <div class="post-grid">
      {pagePosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <nav class="pagination-nav">
      {pagination.prev !== null ? (
        <a
          href={pagination.prev === 0 ? "/" : `/indexes/${pagination.prev}/`}
          class="pagination-link"
        >
          ← 前
        </a>
      ) : (
        <span></span>
      )}
      <span class="page-indicator">
        {pageNum + 1} / {pagination.total}
      </span>
      {pagination.next !== null ? (
        <a href={`/indexes/${pagination.next}/`} class="pagination-link">
          次 →
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </div>
</BaseLayout>

<style>
  .index-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .pagination-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
  }

  .pagination-link {
    display: inline-block;
    padding: 8px 24px;
    border: 1px solid #f48fb1;
    border-radius: 4px;
    color: #f48fb1;
    text-decoration: none;
    font-weight: 600;
    transition: all 200ms ease;
  }

  .pagination-link:hover {
    background: #f48fb1;
    color: white;
  }

  .page-indicator {
    font-size: 0.875rem;
    color: #888;
  }
</style>
