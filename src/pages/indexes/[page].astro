---
import BaseLayout from "@components/BaseLayout.astro"
import PostCard from "@components/PostCard.astro"
import { getAllPosts } from "@lib/posts"
import { getPaginationInfo, getPageSlice } from "@lib/pagination"
import { SITE_CONFIG, POSTS_PER_PAGE } from "@lib/site"

const defaultOgImage = `${SITE_CONFIG.url}/og-default.jpg`

export interface Params {
  page: string
}

export async function getStaticPaths() {
  const allPosts = await getAllPosts()
  const total = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE))
  const paths = []
  for (let i = 1; i < total; i++) {
    paths.push({ params: { page: String(i) } })
  }
  return paths
}

const { page } = Astro.params
const pageNum = parseInt(page ?? "0", 10)

const allPosts = await getAllPosts()
const pagination = getPaginationInfo(allPosts.length, pageNum)
const pagePosts = getPageSlice(allPosts, pageNum)
const canonicalUrl =
  pageNum === 0
    ? `${SITE_CONFIG.url}/`
    : `${SITE_CONFIG.url}/indexes/${pageNum}/`
---

<BaseLayout
  title={`${SITE_CONFIG.title} — ${pageNum + 1}ページ目`}
  isHome={true}
  image={defaultOgImage}
  canonicalUrl={canonicalUrl}
>
  <div class="index-wrap">
    <div class="post-grid">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>

    <nav class="pagination-nav" aria-label="ページナビゲーション">
      {
        pagination.prev !== null ? (
          <a
            href={pagination.prev === 0 ? "/" : `/indexes/${pagination.prev}/`}
            class="pagination-link"
          >
            ← 前のページ
          </a>
        ) : (
          <span />
        )
      }
      <span class="page-indicator">
        ページ {pageNum + 1} / {pagination.total}
      </span>
      {
        pagination.next !== null ? (
          <a href={`/indexes/${pagination.next}/`} class="pagination-link">
            次のページ →
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</BaseLayout>

<style>
  .index-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 8px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }

  .pagination-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 40px;
  }

  .pagination-link {
    display: inline-block;
    padding: 10px 28px;
    border: 1.5px solid var(--color-accent);
    border-radius: 9999px;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    transition:
      background 200ms ease,
      color 200ms ease;
  }

  .pagination-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .page-indicator {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
</style>
