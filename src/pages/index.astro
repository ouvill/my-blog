---
import BaseLayout from "@components/BaseLayout.astro"
import PostCard from "@components/PostCard.astro"
import { getAllPosts } from "@lib/posts"
import { getPaginationInfo, getPageSlice } from "@lib/pagination"
import { SITE_CONFIG } from "@lib/site"
import {
  collectTaxonomyItems,
  getPostCategory,
  getPostTags,
  taxonomyPath,
} from "@lib/taxonomy"
import { blogEntryIdToSlug, blogUrlPath } from "@lib/slug"
import { resolveCoverImageOrNull } from "@lib/cover"
import { descriptionOrExcerpt } from "@lib/excerpt"

const allPosts = await getAllPosts()
const pagination = getPaginationInfo(allPosts.length, 0)
const pagePosts = getPageSlice(allPosts, 0)
const defaultOgImage = `${SITE_CONFIG.url}/og-default.jpg`
const featuredPost = allPosts[0]
const featuredSlug = featuredPost ? blogEntryIdToSlug(featuredPost.id) : null
const featuredCover = featuredPost
  ? resolveCoverImageOrNull(featuredPost)
  : null
const featuredTags = featuredPost ? getPostTags(featuredPost).slice(0, 3) : []
const featuredCategory = featuredPost ? getPostCategory(featuredPost) : null
const featuredExcerpt = featuredPost
  ? descriptionOrExcerpt(featuredPost.data.description, featuredPost.body)
  : null
const allCategories = collectTaxonomyItems(allPosts, "categories")
const categories = allCategories.slice(0, 8)
const tags = collectTaxonomyItems(allPosts, "tags").slice(0, 12)
const years = new Set(allPosts.map((post) => post.data.date.getFullYear()))
---

<BaseLayout
  title={SITE_CONFIG.title}
  isHome={true}
  image={defaultOgImage}
  canonicalUrl={`${SITE_CONFIG.url}/`}
>
  <div class="index-wrap">
    <section class="home-overview" aria-label="ブログ概要">
      {
        featuredPost && featuredSlug && (
          <article
            class={`featured-post${featuredCover ? "" : " featured-post--text-only"}`}
          >
            {featuredCover && (
              <a href={blogUrlPath(featuredSlug)} class="featured-cover">
                <img
                  src={featuredCover.src}
                  alt=""
                  loading="eager"
                  width={featuredCover.width}
                  height={featuredCover.height}
                />
              </a>
            )}
            <div class="featured-body">
              <p class="section-kicker">最新記事</p>
              <h1 class="featured-title">
                <a href={blogUrlPath(featuredSlug)}>
                  {featuredPost.data.title}
                </a>
              </h1>
              {featuredExcerpt && (
                <p class="featured-description">{featuredExcerpt}</p>
              )}
              <div class="featured-meta">
                <time datetime={featuredPost.data.date.toISOString()}>
                  {featuredPost.data.date.toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {featuredCategory && (
                  <a href={taxonomyPath("categories", featuredCategory)}>
                    {featuredCategory}
                  </a>
                )}
              </div>
              {featuredTags.length > 0 && (
                <div class="featured-tags">
                  {featuredTags.map((tag) => (
                    <a href={taxonomyPath("tags", tag)}>{tag}</a>
                  ))}
                </div>
              )}
              <a href={blogUrlPath(featuredSlug)} class="featured-read-more">
                続きを読む
              </a>
            </div>
          </article>
        )
      }

      <aside class="discovery-panel" aria-label="記事の探し方">
        <div class="stats-grid">
          <div>
            <span class="stat-value">{allPosts.length}</span>
            <span class="stat-label">記事</span>
          </div>
          <div>
            <span class="stat-value">{allCategories.length}</span>
            <span class="stat-label">カテゴリ</span>
          </div>
          <div>
            <span class="stat-value">{years.size}</span>
            <span class="stat-label">年分</span>
          </div>
        </div>

        {
          categories.length > 0 && (
            <div class="taxonomy-block">
              <h2>カテゴリ</h2>
              <div class="category-list">
                {categories.map((category) => (
                  <a href={category.href}>
                    <span>{category.name}</span>
                    <strong>{category.count}</strong>
                  </a>
                ))}
              </div>
            </div>
          )
        }

        {
          tags.length > 0 && (
            <div class="taxonomy-block">
              <h2>よく使うタグ</h2>
              <div class="tag-cloud">
                {tags.map((tag) => (
                  <a href={tag.href}>
                    {tag.name}
                    <span>{tag.count}</span>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </section>

    <div class="section-heading">
      <div>
        <p class="section-kicker">All Posts</p>
        <h2>新着記事</h2>
      </div>
      <span>{pagination.total} ページ中 1 ページ目</span>
    </div>

    <div class="post-grid">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>

    <nav class="pagination-nav" aria-label="ページナビゲーション">
      <span></span>
      {
        pagination.next !== null && (
          <a href={`/indexes/${pagination.next}/`} class="pagination-link">
            次のページ →
          </a>
        )
      }
    </nav>
  </div>
</BaseLayout>

<style>
  .index-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 32px 16px 0;
  }

  .home-overview {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
    gap: 24px;
    align-items: stretch;
    margin-bottom: 40px;
  }

  .featured-post,
  .discovery-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .featured-post {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, 0.95fr) minmax(0, 1fr);
  }

  .featured-post::before {
    content: "";
    position: absolute;
    right: -46px;
    bottom: -78px;
    width: 220px;
    height: 220px;
    background: url("/cherry-blossom.svg") center / contain no-repeat;
    opacity: 0.08;
    transform: rotate(18deg);
    pointer-events: none;
  }

  .featured-post::after {
    content: "";
    position: absolute;
    inset: 12px;
    border: 1px solid
      color-mix(in srgb, var(--color-accent-soft) 65%, transparent);
    border-radius: 10px;
    pointer-events: none;
  }

  .featured-post--text-only {
    grid-template-columns: 1fr;
  }

  .featured-post--text-only .featured-body {
    min-height: 300px;
  }

  .featured-cover {
    min-height: 100%;
    background: var(--color-accent-soft);
  }

  .featured-cover img {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
  }

  .featured-body {
    position: relative;
    z-index: 1;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .section-kicker {
    margin: 0 0 8px;
    color: var(--color-support);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.75rem;
    line-height: 1.45;
    font-feature-settings: "palt";
  }

  .featured-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--color-accent);
  }

  .featured-description {
    margin: 12px 0 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 36rem;
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 18px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .featured-meta a,
  .featured-tags a {
    text-decoration: none;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }

  .featured-read-more {
    align-self: flex-start;
    margin-top: 20px;
    padding: 9px 18px;
    border-radius: 9999px;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 8px 18px rgba(196, 83, 111, 0.16);
    transition:
      transform 200ms ease,
      background 200ms ease;
  }

  .featured-read-more:hover {
    background: var(--color-accent-strong);
    transform: translateY(-1px);
  }

  .featured-tags a,
  .tag-cloud a {
    padding: 4px 10px;
    border-radius: 9999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .discovery-panel {
    padding: 22px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 22px;
  }

  .stats-grid div {
    padding: 12px 8px;
    border-radius: 12px;
    background: var(--color-support-soft);
    text-align: center;
  }

  .stat-value,
  .stat-label {
    display: block;
  }

  .stat-value {
    color: var(--color-support-strong);
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .stat-label {
    color: var(--color-text-secondary);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .taxonomy-block + .taxonomy-block {
    margin-top: 20px;
  }

  .taxonomy-block h2 {
    margin: 0 0 10px;
    font-size: 0.95rem;
    font-family: var(--font-heading);
  }

  .category-list {
    display: grid;
    gap: 8px;
  }

  .category-list a {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 10px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .category-list a:hover {
    color: var(--color-support-strong);
    border-color: var(--color-support);
  }

  .category-list strong {
    color: var(--color-text-muted);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-cloud span {
    margin-left: 5px;
    color: var(--color-text-muted);
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 20px;
    margin-bottom: 18px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1.35rem;
    font-family: var(--font-heading);
  }

  .section-heading > span {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .post-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 14px;
  }

  .pagination-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 40px;
  }

  .pagination-link {
    display: inline-block;
    padding: 10px 28px;
    border: 1.5px solid var(--color-accent);
    border-radius: 9999px;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    transition:
      background 200ms ease,
      color 200ms ease;
  }

  .pagination-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 860px) {
    .home-overview,
    .featured-post {
      grid-template-columns: 1fr;
    }

    .featured-cover img {
      min-height: 220px;
    }
  }

  @media (max-width: 560px) {
    .index-wrap {
      padding-top: 24px;
    }

    .featured-body,
    .discovery-panel {
      padding: 18px;
    }

    .featured-title {
      font-size: 1.35rem;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
