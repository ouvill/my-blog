---
import BaseLayout from "@components/BaseLayout.astro"

const title = "ページが見つかりません"
---

<BaseLayout title={title}>
  <div class="not-found">
    <h1>404</h1>
    <p>お探しのページは見つかりませんでした。</p>
    <a href="/">トップページに戻る</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 64px 16px;
  }

  .not-found h1 {
    font-size: 4rem;
    margin: 0;
    color: #f48fb1;
  }

  .not-found p {
    margin: 16px 0 24px;
    font-size: 1.125rem;
    color: #666;
  }

  .not-found a {
    display: inline-block;
    padding: 8px 24px;
    border: 1px solid #f48fb1;
    border-radius: 4px;
    color: #f48fb1;
    text-decoration: none;
    font-weight: 600;
  }

  .not-found a:hover {
    background: #f48fb1;
    color: white;
  }
</style>
