---
import BaseLayout from "@components/BaseLayout.astro"

const title = "お問い合わせを受け付けました"
---

<BaseLayout title={title} noindex>
  <div class="success-page">
    <img
      src="/cherry-blossom.svg"
      alt=""
      width="56"
      height="56"
      class="success-icon"
    />
    <h1>お問い合わせを受け付けました</h1>
    <p>お問い合わせいただきありがとうございます。</p>
    <p>内容を確認の上、追ってご連絡いたします。</p>
    <a href="/" class="home-link">トップページに戻る</a>
  </div>
</BaseLayout>

<style>
  .success-page {
    text-align: center;
    padding: 64px 16px;
    max-width: 560px;
    margin: 0 auto;
    background: var(--color-surface);
    border-radius: 16px;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
  }

  .success-icon {
    display: block;
    margin: 0 auto 20px;
    opacity: 0.75;
  }

  .success-page h1 {
    font-size: 1.5rem;
    margin: 0 0 20px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-feature-settings: "palt";
    color: var(--color-text);
  }

  .success-page p {
    margin: 10px 0;
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .home-link {
    display: inline-block;
    margin-top: 28px;
    padding: 10px 32px;
    border: 1.5px solid var(--color-accent);
    border-radius: 9999px;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition:
      background 200ms ease,
      color 200ms ease;
  }

  .home-link:hover {
    background: var(--color-accent);
    color: #fff;
  }
</style>
